# ============================================================
# Supabase — Backend as a Service
# ============================================================
# Get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================================
# Analytics — all optional, only loaded with full cookie consent
# ============================================================

# Google Analytics 4
# Get your Measurement ID from: GA4 → Admin → Data Streams → Web stream → Measurement ID
# Format: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog — Product analytics & session recording
# Get your Project API Key from: PostHog → Project Settings → Project API Key
VITE_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# PostHog API host — use EU region for GDPR compliance (default)
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# Plausible — Privacy-friendly page-view analytics
# Set this to your site's domain as registered in Plausible (e.g. patentehub.com)
VITE_PLAUSIBLE_DOMAIN=patentehub.com

# ============================================================
# Error Tracking & Session Monitoring
# ============================================================

# Sentry — Error tracking & performance monitoring (no consent required)
# Get your DSN from: sentry.io → Project → Settings → Client Keys (DSN)
# Format: https://<key>@<org>.ingest.sentry.io/<project-id>
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxx@o0000000.ingest.sentry.io/0000000000
# Environment label sent with every event (production | staging | development)
VITE_SENTRY_ENVIRONMENT=production

# LogRocket — Session replay & frontend logging (requires full cookie consent)
# Get your App ID from: app.logrocket.com → Settings → General → App ID
# Format: orgslug/appslug
VITE_LOGROCKET_APP_ID=your-org/patentehub
